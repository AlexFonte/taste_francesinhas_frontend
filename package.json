{
  "name": "taste-francesinhas-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "clean": "rimraf .angular/cache dist node_modules/.cache",
    "start": "ng serve --proxy-config proxy.conf.json",
    "dev:serve": "ng serve --host 0.0.0.0 --proxy-config proxy.conf.json",
    "dev": "run-s clean dev:serve",
    "prebuild": "npm run clean",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "material-symbols": "^0.44.4",
    "postcss": "^8.5.10",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
